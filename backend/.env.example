# Golf Charity Platform — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/golf_charity

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# Subscription prices in pence (999 = £9.99, 9999 = £99.99)
MONTHLY_PRICE_PENCE=999
YEARLY_PRICE_PENCE=9999

# Prize pool contribution per subscriber per month (in £)
PRIZE_CONTRIBUTION_MONTHLY=5
PRIZE_CONTRIBUTION_YEARLY=50

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
